# Copy this file to `.env` and fill in the values after provisioning Azure
# resources (see docs/azure-setup.md). `.env` is gitignored; never commit real keys.

# --- Azure OpenAI (Australia East) ---
# Endpoint and key from the Azure OpenAI resource "Keys and Endpoint" blade.
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
# Deployment NAMES you chose when creating the deployments (not the model names).
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Azure AI Search (Australia East) ---
# Endpoint from the search service Overview; key from "Keys" (admin key).
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<your-azure-search-admin-key>
AZURE_SEARCH_INDEX_NAME=nist-800-53-controls
# true requires Basic tier or above (semantic ranker). Set false on the Free tier.
AZURE_SEARCH_SEMANTIC_RANKER=true

# --- Retrieval & determinism ---
# Number of documents retrieved per plan step (task requires top 3-5).
RETRIEVAL_TOP_K=5
# Relevance floors below which a retrieved control is dropped (safe-fallback
# guard). Exactly one applies, chosen by AZURE_SEARCH_SEMANTIC_RANKER above,
# because the two search modes rank on different, incomparable score scales.
# Used when the ranker is on: `@search.rerankerScore`, scale 0-4.
MIN_RERANKER_SCORE=1.8
# Used when the ranker is off: vector `@search.score`, a rescaled cosine in 0-1.
MIN_VECTOR_SCORE=0.60
# Show the Planner the corpus map: the 20 NIST SP 800-53 control families and what
# each covers (llm_policy_library/corpus_map.json, regenerated by
# `python -m llm_policy_library.build_map`). It costs ~1,053 input tokens (measured)
# on every planner call and buys a STRUCTURAL refusal path: when the Planner judges no
# family covers the question, the pipeline skips retrieval entirely and serves the
# safe fallback. The judgement is the model's, so it is not a guaranteed classifier;
# what is fixed is what follows it. With this false the Planner plans blind and an
# off-topic question is refused only when retrieval happens to find nothing above
# the relevance floor -- which it usually does, but not reliably.
# Decided by A/B over 3 evaluation runs per setting (TODO.md, decision D12).
PLANNER_CORPUS_MAP=true
# Reasoning effort for the gpt-5-family chat model. Low effort minimizes latency
# and output variance (determinism now rests on structured outputs + grounding,
# not temperature/seed, which the reasoning models reject). Use "minimal" for
# gpt-5-mini; "none" is valid for gpt-5.1.
LLM_REASONING_EFFORT=minimal

# --- Public exposure: abuse and cost controls (POST /query only) ---
# The service is public and unauthenticated, so these bound the Azure OpenAI bill.
# Set BOTH to 0 when running the load test: it drives ~63 requests/minute from one
# address, and would otherwise measure the rate limiter instead of the pipeline.
#
# Both are SUSTAINED rates. A token bucket keeps a full bucketful in reserve, so
# the worst case in any 60s window is the burst plus a minute's refill -- TWICE
# the number set here. Size them against 2x.
#
# Per caller, per minute. A query takes ~7s, so a human sustains at most ~8/min.
RATE_LIMIT_PER_IP_PER_MINUTE=10
# Per process, per minute -- the backstop the per-caller budget cannot provide,
# since many callers each under their own limit still drain the quota. The chat
# deployment allows 150 RPM and a request spends ~2 chat calls, so ~75 req/min
# exhausts it. At 30 sustained the 2x worst case is 60 req/min (~120 chat calls),
# comfortably inside quota.
RATE_LIMIT_GLOBAL_PER_MINUTE=30
# Seconds POST /query waits for the pipeline before answering 504. Well above the
# measured p99 (~11s), and below the frontend's own 120s abort.
REQUEST_TIMEOUT_SECONDS=60

# --- Logging ---
LOG_LEVEL=INFO
