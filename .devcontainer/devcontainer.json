{
    "image": "python:3.14-trixie",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "configureZshAsDefaultShell": "true",
            "username": "vscode"
        }
    },
    "remoteUser": "vscode",
    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly",
        "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
        "source=${localEnv:HOME}/.claude/plugins/installed_plugins.json,target=/home/vscode/.claude/plugins/installed_plugins.json,type=bind"
    ],
    "postCreateCommand": "chmod +x .devcontainer/postCreateCommand.sh && ./.devcontainer/postCreateCommand.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code",
                "charliermarsh.ruff",
                "mhutchie.git-graph",
                "ms-python.debugpy",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-vscode.live-server",
                "openai.chatgpt",
                "ryu1kn.partial-diff",
                "streetsidesoftware.code-spell-checker",
                "tamasfe.even-better-toml",
                "yzhang.markdown-all-in-one"
            ]
        }
    }
}
