# Copy this file to `.env` and fill in the values after provisioning Azure
# resources (see docs/azure-setup.md). `.env` is gitignored; never commit real keys.

# --- Azure OpenAI (Australia East) ---
# Endpoint and key from the Azure OpenAI resource "Keys and Endpoint" blade.
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
# Deployment NAMES you chose when creating the deployments (not the model names).
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Azure AI Search (Australia East) ---
# Endpoint from the search service Overview; key from "Keys" (admin key).
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<your-azure-search-admin-key>
AZURE_SEARCH_INDEX_NAME=nist-800-53-controls
# true requires Basic tier or above (semantic ranker). Set false on the Free tier.
AZURE_SEARCH_SEMANTIC_RANKER=true

# --- Retrieval & determinism ---
# Number of documents retrieved per plan step (task requires top 3-5).
RETRIEVAL_TOP_K=5
# Drop retrieved documents scoring below this threshold (safe-fallback guard).
MIN_RELEVANCE_SCORE=0.02
# Reasoning effort for the gpt-5-family chat model. Low effort minimizes latency
# and output variance (determinism now rests on structured outputs + grounding,
# not temperature/seed, which the reasoning models reject). Use "minimal" for
# gpt-5-mini; "none" is valid for gpt-5.1.
LLM_REASONING_EFFORT=minimal

# --- Logging ---
LOG_LEVEL=INFO
